generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum RoleType {
  ADMIN
  DOCTOR
  PATIENT
  LAB_TECHNICIAN
  PHARMACIST
  EMERGENCY_STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  MANAGE
}

enum StaffStatus {
  ACTIVE
  LEAVE
  INACTIVE
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum RoomType {
  GENERAL
  ICU
  PRIVATE
  EMERGENCY
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

model User {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String          @unique
  passwordHash        String
  passwordChangedAt   DateTime?
  status              UserStatus      @default(ACTIVE)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  roleId              String          @db.Uuid
  role                Role            @relation(fields: [roleId], references: [id])
  patient             Patient?
  doctor              Doctor?
  admin               Admin?
  labTechnician       LabTechnician?
  pharmacist          Pharmacist?
  emergencyStaff      EmergencyStaff?
  sessions            Session[]
  refreshTokens       RefreshToken[]
  loginHistories      LoginHistory[]
  auditLogs           AuditLog[]
  failedLoginAttempts Int             @default(0)
  lockedUntil         DateTime?
  aiRequests          AIRequest[]
  notifications       Notification[]
  offlineSyncs        OfflineSync[]

  @@index([email])
  @@index([roleId])
}

model Role {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String           @unique
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String           @unique
  action PermissionAction
  roles  RolePermission[]
}

model RolePermission {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model LoginHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Hospital {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  address     String?
  phone       String?
  departments Department[]
  rooms       Room[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  emergencies Emergency[]
}

model Department {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  status     DepartmentStatus @default(ACTIVE)
  hospitalId String           @db.Uuid
  hospital   Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  doctors    Doctor[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([hospitalId])
}

model Room {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomNumber String
  type       RoomType
  hospitalId String   @db.Uuid
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  beds       Bed[]
  createdAt  DateTime @default(now())

  @@index([hospitalId])
}

model Bed {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bedNumber String
  status    BedStatus @default(AVAILABLE)
  roomId    String    @db.Uuid
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([roomId])
}

model Patient {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String            @unique @db.Uuid
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          Gender
  phone           String?
  address         String?
  bloodGroup      String?
  insuranceNumber String?
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  prescriptions   Prescription[]
  emergencies     Emergency[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  timeline        PatientTimeline[]
  labTests        LabTest[]
  invoices        Invoice[]

  @@index([userId])
}

model Doctor {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String          @unique @db.Uuid
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  specialization String
  licenseNumber  String          @unique
  departmentId   String          @db.Uuid
  department     Department      @relation(fields: [departmentId], references: [id])
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  prescriptions  Prescription[]
  status         StaffStatus     @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([departmentId])
}

model Admin {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  createdAt DateTime @default(now())
}

model LabTechnician {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String      @unique @db.Uuid
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  employeeId String      @unique
  status     StaffStatus @default(ACTIVE)
  createdAt  DateTime    @default(now())
  labTests   LabTest[]
}

model Pharmacist {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String      @unique @db.Uuid
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  licenseId String      @unique
  status    StaffStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
}

model EmergencyStaff {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String      @unique @db.Uuid
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  shiftInfo String?
  status    StaffStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId       String            @db.Uuid
  doctorId        String            @db.Uuid

  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          Doctor            @relation(fields: [doctorId], references: [id])

  appointmentDate DateTime

  reason          String
  notes           String?

  status          AppointmentStatus @default(SCHEDULED)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([patientId])
  @@index([doctorId])
}

model MedicalRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @db.Uuid
  doctorId    String   @db.Uuid
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  diagnosis   String?
  notes       String?
  attachments String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  triageLogs TriageLog[]
  @@index([patientId])
  @@index([doctorId])
}

model Prescription {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId    String                 @db.Uuid
  doctorId     String                 @db.Uuid
  patient      Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       Doctor                 @relation(fields: [doctorId], references: [id])
  medicine     String
  dosage       String
  instructions String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  medicines    PrescriptionMedicine[]

  @@index([patientId])
  @@index([doctorId])
}

enum EmergencyStatus {
  ACTIVE
  RESOLVED
  CANCELLED
  DISPATCHED
}

model Emergency {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String          @db.Uuid
  patient     Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  hospitalId  String?         @db.Uuid
  hospital    Hospital?       @relation(fields: [hospitalId], references: [id])
  status      EmergencyStatus @default(ACTIVE)
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([patientId])
  @@index([hospitalId])
}

model LabTest {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId    String         @db.Uuid
  patient      Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  testName     String
  result       String?
  technicianId String?        @db.Uuid
  technician   LabTechnician? @relation(fields: [technicianId], references: [id])
  createdAt    DateTime       @default(now())

  @@index([patientId])
  @@index([technicianId])
}

model Medicine {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String                 @unique
  manufacturer  String?
  stock         Int                    @default(0)
  price         Float
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  prescriptions PrescriptionMedicine[]
}

model PrescriptionMedicine {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prescriptionId String       @db.Uuid
  medicineId     String       @db.Uuid
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  quantity       Int
  createdAt      DateTime     @default(now())

  @@index([prescriptionId])
  @@index([medicineId])
}

model Invoice {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String   @db.Uuid
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  amount    Float
  paid      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
}

enum NotificationType {
  APPOINTMENT
  EMERGENCY
  BILLING
  SYSTEM
}

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  status      String?
  resourceId String?
  resourceType String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  details Json?
  @@index([userId])
  @@index([entityId])
  @@index([createdAt])
}

model AIRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id])
  prompt     String
  response   String?
  model      String
  tokensUsed Int?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model PatientTimeline {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @db.Uuid
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  eventType   String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([patientId])
  @@index([createdAt])
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

model OfflineSync {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @db.Uuid
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId    String
  payload     Json
  status      SyncStatus @default(PENDING)
  lastAttempt DateTime?
  createdAt   DateTime   @default(now())

  @@index([userId])
  @@index([deviceId])
}

model VitalSigns {
  id                String   @id @default(cuid())
  medicalRecordId   String
  bloodPressure     String?
  heartRate         Int?
  temperature       Float?
  respiratoryRate   Int?
  recordedAt        DateTime @default(now())

  createdAt         DateTime @default(now())
}

model TriageLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  medicalRecordId String   @db.Uuid
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  inputData       String
  outputData      String
  modelUsed       String
  latencyMs       Int

  timestamp       DateTime @default(now())

  @@index([medicalRecordId])
}