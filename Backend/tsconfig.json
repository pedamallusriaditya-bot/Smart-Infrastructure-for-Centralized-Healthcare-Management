{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "outDir": "./dist",
    "allowJs": true,

    // Enforces strict typing
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "alwaysStrict": true,

    // Code quality checks
    "noUnusedLocals": false,
    "noUnusedParameters": true,
    "isolatedModules": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",

    // Explicitly tell TS to look at standard Node types and your custom types
    "typeRoots": ["./node_modules/@types", "./types"],

    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": [
    "src/**/*",
    "tests/**/*",
    "types/**/*",
    "prisma/seed.ts",
    "prisma.config.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}